# Environment Variables Template
# Copy to .env and fill with your values

# =====================
# REQUIRED
# =====================

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_api_key_here

# =====================
# Optional (has defaults)
# =====================

# Environment: development or production
ENVIRONMENT=development

# Backend API URL
API_BASE_URL=http://127.0.0.1:8000

# API request timeout (seconds)
API_REQUEST_TIMEOUT=600

# LLM timeout (seconds, max 60)
LLM_TIMEOUT_SEC=60

# Clone repository timeout (seconds)
CLONE_TIMEOUT_SEC=300

# Code snippet max length (characters)
CODE_SNIPPET_MAX_LENGTH=700

# Routing top_k (1=full LLM only, 2=Top1 LLM + Top2 tool-only)
ROUTING_TOP_K=2

# Temporary repository directory
TEMP_REPO_DIR=temp_repos
